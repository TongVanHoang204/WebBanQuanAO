# =========================
# Root env template
# Use this file as the single source of truth for deploy values.
# For Vercel, copy only the variables that belong to the frontend project.
# Backend variables should be added to the backend host separately.
# =========================

# -------------------------
# Local Docker only
# -------------------------
MYSQL_ROOT_PASSWORD=change-this-database-password
MYSQL_DATABASE=fashion_store

# -------------------------
# Shared app URLs
# -------------------------
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://www.your-domain.com

# -------------------------
# Backend required
# -------------------------
NODE_ENV=production
PORT=4000
DATABASE_URL=mysql://db_user:db_password@db_host:3306/fashion_store
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=shopfeshen_auth
SUPER_ADMIN_ID=1
PAYMENT_TIMEOUT_MINUTES=30

# -------------------------
# Frontend required on Vercel
# These VITE_* variables are frontend-only.
# -------------------------
VITE_API_URL=https://api.your-domain.com/api/v1
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_SUPABASE_URL=https://pbiyscshjajuqoiqrwiv.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_HHJjRVs2bI2mfFvO2HgPbw_5nW6xIDp

# -------------------------
# Google OAuth
# Backend and frontend should use the same client id
# -------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# -------------------------
# Supabase server-side
# Backend should use server-side names, not VITE_*.
# -------------------------
SUPABASE_URL=https://pbiyscshjajuqoiqrwiv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------
# Email / notifications
# Resend is the only provider used by the current codepath
# -------------------------
APP_NAME=ShopFeshen
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@your-domain.com
RESEND_REPLY_TO=support@your-domain.com

# -------------------------
# Payment / webhook
# -------------------------
VNP_RETURN_URL=https://your-frontend-domain.vercel.app/payment/vnpay-return
PAYMENT_WEBHOOK_SECRET=replace-with-a-second-long-random-secret

# -------------------------
# Google Places proxy
# Optional: required only if address autocomplete via RapidAPI is enabled
# -------------------------
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=google-map-places-new-v2.p.rapidapi.com

# -------------------------
# AI / chat
# Gemini is primary. Ollama remains available as optional fallback.
# -------------------------
GEMINI_API_KEY=AIzaSyBkWQe4fzKm_338186Ojq1z03T0xEoftdY
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemini-3-flash-preview:cloud
OLLAMA_VISION_MODEL=gemini-3-flash-preview:cloud
OLLAMA_ALLOW_PUBLIC_DOMAIN=false
OLLAMA_REMOTE_COOLDOWN_MS=300000
