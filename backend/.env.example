# -------------------------
# Backend required
# -------------------------
NODE_ENV=production
PORT=4000
DATABASE_URL=mysql://db_user:db_password@db_host:3306/fashion_store
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=shopfeshen_auth
SUPER_ADMIN_ID=1

# Public app URLs
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://www.your-domain.com

# Background jobs / payment
PAYMENT_TIMEOUT_MINUTES=30
VNP_RETURN_URL=https://your-frontend-domain.vercel.app/payment/vnpay-return
PAYMENT_WEBHOOK_SECRET=replace-with-a-second-long-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Email via Resend
APP_NAME=ShopFeshen
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@your-domain.com
RESEND_REPLY_TO=support@your-domain.com

# Google Places proxy
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=google-map-places-new-v2.p.rapidapi.com

# AI / chat
GEMINI_API_KEY=AIzaSyBkWQe4fzKm_338186Ojq1z03T0xEoftdY
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview

# Optional Ollama fallback
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemini-3-flash-preview:cloud
OLLAMA_VISION_MODEL=gemini-3-flash-preview:cloud
OLLAMA_ALLOW_PUBLIC_DOMAIN=false
OLLAMA_REMOTE_COOLDOWN_MS=300000
